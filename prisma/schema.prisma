// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  CLIENT
  PM
  ADMIN
}

enum PaymentType {
  RETAINER
  SUCCESS
  OTHER
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PaymentProvider {
  PAYSTACK
  MANUAL
  OTHER
}

enum ArticleCategory {
  PRICE_DATA
  LEGAL_GUIDES
  AREA_ANALYSIS
  FRAUD_WARNINGS
  HOW_TO_GUIDES
}

enum IntakeStatus {
  DRAFT
  PENDING
  REVIEWING
  ACTIVE
  CLOSED
}

enum LeadInterestType {
  BUY
  INVEST
  DEVELOP
  LEGAL_SUPPORT
  CROSS_BORDER
}

enum LeadStatus {
  NEW
  CONSULTATION_SCHEDULED
  AWAITING_DECISION
  INTAKE_INVITED
  INTAKE_SUBMITTED
  DECLINED
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  /// Maps to auth.users.id in Supabase — UUID stored as String
  id                 String    @id @db.Uuid
  email              String    @unique
  role               Role      @default(CLIENT)
  createdAt          DateTime  @default(now()) @map("created_at")
  lastLogin          DateTime? @map("last_login")

  // Profile — shared across all roles
  fullName           String?   @map("full_name")
  preferredName      String?   @map("preferred_name")
  phone              String?
  photoUrl           String?   @map("photo_url")

  // Client-only fields (nullable; only populated when role = CLIENT)
  nationality        String?
  location           String?
  idType             String?   @map("id_type")
  idNumber           String?   @map("id_number")
  onboardingComplete Boolean   @default(false) @map("onboarding_complete")

  // PM assigned to this client (null for PM/ADMIN users)
  assignedPmId       String?   @map("assigned_pm_id") @db.Uuid
  assignedPm         User?     @relation("ClientPm", fields: [assignedPmId], references: [id], onDelete: SetNull)
  managedClients     User[]    @relation("ClientPm")

  // Client's PM-change request flags
  pmChangeRequested  Boolean   @default(false) @map("pm_change_requested")
  pmChangeReason     String?   @map("pm_change_reason")

  // Relations
  enquiries          Enquiry[]
  engagements        Engagement[]
  managedEngagements Engagement[]   @relation("EngagementPm")
  notifications      Notification[]
  sentMessages       Message[]      @relation("SentMessages")
  auditLogs          AuditLog[]
  updates            Update[]
  articles           Article[]
  intakeSubmissions  IntakeSubmission[]
  leadAsClient       Lead?          @relation("LeadClient")
  assignedLeads      Lead[]         @relation("LeadPm")
  evaluationsAsPm    ClientEvaluation[] @relation("EvaluationPm")
  meetingsAsPm       StrategyMeeting[]  @relation("MeetingPm")
  serviceTiersCreated ServiceTier[]
  signedAgreements   ServiceAgreement[] @relation("AgreementSigner")

  @@map("users")
}

model Enquiry {
  id              String   @id @default(cuid())
  userId          String   @map("user_id") @db.Uuid
  source          String?
  transactionType String?  @map("transaction_type")
  brief           String?
  status          String   @default("open")
  assignedAdvisor String?  @map("assigned_advisor")
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("enquiries")
}

model Engagement {
  id              String    @id @default(cuid())
  userId          String    @map("user_id") @db.Uuid
  pmId            String?   @map("pm_id") @db.Uuid
  serviceTier     String?   @map("service_tier")
  serviceTierId   String?   @map("service_tier_id")
  stage           String    @default("discovery")
  startDate       DateTime? @map("start_date")
  targetDate      DateTime? @map("target_date")
  status          String    @default("active")

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents        Document[]
  updates          Update[]
  messages         Message[]
  payments         Payment[]
  pendingActions   PendingAction[]
  invoices         Invoice[]
  agreement        ServiceAgreement?
  strategyMeetings StrategyMeeting[]
  pm               User?      @relation("EngagementPm", fields: [pmId], references: [id], onDelete: SetNull)
  tierRef          ServiceTier? @relation(fields: [serviceTierId], references: [id], onDelete: SetNull)

  @@map("engagements")
}

model PendingAction {
  id           String    @id @default(cuid())
  engagementId String    @map("engagement_id")
  title        String
  type         String    @default("OTHER")
  dueDate      DateTime? @map("due_date")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  engagement Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@map("pending_actions")
}

model Document {
  id              String   @id @default(cuid())
  engagementId    String   @map("engagement_id")
  name            String
  title           String?
  category        String?
  filePath        String   @map("file_path")
  uploadedBy      String   @map("uploaded_by") @db.Uuid
  uploadedAt      DateTime @default(now()) @map("uploaded_at")
  version         Int      @default(1)
  isClientVisible Boolean  @default(true) @map("is_client_visible")

  engagement Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@map("documents")
}

model Update {
  id           String    @id @default(cuid())
  engagementId String    @map("engagement_id")
  pmId         String    @map("pm_id") @db.Uuid
  content      String
  nextSteps    String?   @map("next_steps")
  publishedAt  DateTime? @map("published_at")
  draft        Boolean   @default(true)

  engagement Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  pm         User       @relation(fields: [pmId], references: [id])

  @@map("updates")
}

model Message {
  id             String    @id @default(cuid())
  engagementId   String    @map("engagement_id")
  senderId       String    @map("sender_id") @db.Uuid
  body           String
  attachmentPath String?   @map("attachment_path")
  sentAt         DateTime  @default(now()) @map("sent_at")
  readAt         DateTime? @map("read_at")

  engagement Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  sender     User       @relation("SentMessages", fields: [senderId], references: [id])

  @@map("messages")
}

model Payment {
  id           String        @id @default(cuid())
  engagementId String        @map("engagement_id")
  type         PaymentType   @default(OTHER)
  amount       Float
  currency     String        @default("NGN")
  provider     PaymentProvider @default(PAYSTACK)
  status       PaymentStatus @default(PENDING)
  reference    String?       @unique
  paidAt       DateTime?     @map("paid_at")
  createdAt    DateTime      @default(now()) @map("created_at")

  engagement Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id") @db.Uuid
  type      String
  content   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Article {
  id          String          @id @default(cuid())
  slug        String          @unique
  title       String
  excerpt     String
  authorId    String          @map("author_id") @db.Uuid
  author      User            @relation(fields: [authorId], references: [id])
  publishedAt DateTime        @map("published_at")
  readTime    Int             @map("read_time")
  category    ArticleCategory
  image       String
  featured    Boolean         @default(false)
  body        String?
  published   Boolean         @default(true)
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@map("articles")
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String   @map("user_id") @db.Uuid
  action       String
  resourceType String   @map("resource_type")
  resourceId   String?  @map("resource_id")
  metadata     Json?
  ipAddress    String?  @map("ip_address")
  timestamp    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([resourceType, resourceId])
  @@index([timestamp])
  @@map("audit_log")
}

model IntakeSubmission {
  id                String       @id @default(cuid())
  referenceNumber   String       @unique @map("reference_number")
  status            IntakeStatus @default(PENDING)

  // Optional link to a user account (created on submit)
  userId            String?      @map("user_id") @db.Uuid
  user              User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Step 1 — Goal
  transactionType   String       @map("transaction_type")
  purpose           String?

  // Step 2 — About you
  fullName          String       @map("full_name")
  preferredName     String?      @map("preferred_name")
  email             String
  phone             String
  location          String
  nationality       String?

  // Step 3 — Property
  targetAreas       String[]     @map("target_areas")
  propertyType      String?      @map("property_type")
  bedrooms          String?
  floorAreaSqm      String?      @map("floor_area_sqm")
  mustHaves         String[]     @map("must_haves")
  dealBreakers      String?      @map("deal_breakers")

  // Step 4 — Budget
  currency          String       @default("NGN")
  budgetMin         String?      @map("budget_min")
  budgetMax         String?      @map("budget_max")
  sourceOfFunds     String?      @map("source_of_funds")
  mortgageStatus    String?      @map("mortgage_status")

  // Step 5 — Timeline & background
  targetDate        String?      @map("target_date")
  decisionSpeed     String?      @map("decision_speed")
  decisionMakers    String?      @map("decision_makers")
  priorExperience   String?      @map("prior_experience")
  riskProfile       String?      @map("risk_profile")
  referralSource    String?      @map("referral_source")

  // Consent
  dataConsent       Boolean      @default(false) @map("data_consent")

  // Draft save-and-continue
  draftStep         Int?         @map("draft_step")

  // Optional link to originating lead
  leadId            String?      @unique @map("lead_id")
  lead              Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)

  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  evaluation        ClientEvaluation?

  @@map("intake_submissions")
}

model Lead {
  id                 String           @id @default(cuid())

  // Contact info (required)
  fullName           String           @map("full_name")
  phone              String
  email              String

  // Optional screening info
  location           String?
  interestType       LeadInterestType? @map("interest_type")

  // Lifecycle
  status             LeadStatus       @default(NEW)
  notes              String?

  // PM assignment
  assignedPmId       String?          @map("assigned_pm_id") @db.Uuid
  assignedPm         User?            @relation("LeadPm", fields: [assignedPmId], references: [id], onDelete: SetNull)

  // Portal account link (set when intake invitation is accepted)
  userId             String?          @unique @map("user_id") @db.Uuid
  user               User?            @relation("LeadClient", fields: [userId], references: [id], onDelete: SetNull)

  // Calendar scheduling
  calendarUrl        String?          @map("calendar_url")
  calendarSentAt     DateTime?        @map("calendar_sent_at")

  // Intake invitation token
  inviteToken        String?          @unique @map("invite_token")
  inviteTokenExpiry  DateTime?        @map("invite_token_expiry")
  inviteSentAt       DateTime?        @map("invite_sent_at")

  // Decline tracking
  declinedAt         DateTime?        @map("declined_at")

  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  // Intake submission created from this lead
  intakeSubmission   IntakeSubmission?

  @@map("leads")
}

// ─── Phase 4–6 Models ─────────────────────────────────────────────────────────

model ClientEvaluation {
  id                   String   @id @default(cuid())
  intakeSubmissionId   String   @unique @map("intake_submission_id")
  pmId                 String   @map("pm_id") @db.Uuid

  legalScore           Int?     @map("legal_score")
  legalNotes           String?  @map("legal_notes")
  financialScore       Int?     @map("financial_score")
  financialNotes       String?  @map("financial_notes")
  marketScore          Int?     @map("market_score")
  marketNotes          String?  @map("market_notes")
  taxNotes             String?  @map("tax_notes")
  riskScore            Int?     @map("risk_score")
  riskNotes            String?  @map("risk_notes")
  crossBorderNotes     String?  @map("cross_border_notes")
  overallRecommendation String? @map("overall_recommendation")
  completedAt          DateTime? @map("completed_at")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  intakeSubmission IntakeSubmission @relation(fields: [intakeSubmissionId], references: [id], onDelete: Cascade)
  pm               User            @relation("EvaluationPm", fields: [pmId], references: [id])

  @@map("client_evaluations")
}

model StrategyMeeting {
  id           String    @id @default(cuid())
  engagementId String    @map("engagement_id")
  pmId         String    @map("pm_id") @db.Uuid
  title        String?
  scheduledAt  DateTime  @map("scheduled_at")
  meetingLink  String?   @map("meeting_link")
  notes        String?
  status       String    @default("SCHEDULED")
  sentAt       DateTime? @map("sent_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  engagement Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  pm         User       @relation("MeetingPm", fields: [pmId], references: [id])

  @@map("strategy_meetings")
}

model ServiceTier {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  price       Float
  currency    String   @default("NGN")
  isActive    Boolean  @default(true) @map("is_active")
  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  engagements Engagement[]
  createdBy   User?      @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@map("service_tiers")
}

model ServiceAgreement {
  id                String    @id @default(cuid())
  engagementId      String    @unique @map("engagement_id")
  serviceTier       String?   @map("service_tier")
  scopeDescription  String    @map("scope_description")
  timeline          String?
  deliverables      String[]
  feeAmount         Float     @map("fee_amount")
  currency          String    @default("NGN")
  terms             String
  version           Int       @default(1)
  status            String    @default("PENDING")
  signedAt            DateTime? @map("signed_at")
  signerName          String?   @map("signer_name")
  signatureImageUrl   String?   @map("signature_image_url")
  signedByUserId      String?   @map("signed_by_user_id") @db.Uuid
  generatedAt         DateTime  @default(now()) @map("generated_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  engagement   Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  signedByUser User?      @relation("AgreementSigner", fields: [signedByUserId], references: [id], onDelete: SetNull)
  invoices     Invoice[]

  @@map("service_agreements")
}

model Invoice {
  id                 String    @id @default(cuid())
  engagementId       String    @map("engagement_id")
  invoiceNumber      String    @unique @map("invoice_number")
  description        String
  amount             Float
  currency           String    @default("NGN")
  status             String    @default("DRAFT")
  dueDate            DateTime? @map("due_date")
  issuedAt           DateTime? @map("issued_at")
  paidAt             DateTime? @map("paid_at")
  paystackReference  String?   @unique @map("paystack_reference")
  serviceAgreementId String?   @map("service_agreement_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  engagement       Engagement        @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  serviceAgreement ServiceAgreement? @relation(fields: [serviceAgreementId], references: [id], onDelete: SetNull)

  @@map("invoices")
}
